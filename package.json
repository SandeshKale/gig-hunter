{
  "name": "gig-hunter",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "lint": "eslint lib src --ext js,jsx --report-unused-disable-directives --max-warnings 0",
    "format": "prettier --write lib src",
    "format:check": "prettier --check lib src",
    "ci": "npm run lint && npm run format:check && npm run test"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.43.0",
    "groq-sdk": "^1.2.0",
    "lucide-react": "^0.383.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "rss-parser": "^3.13.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.1",
    "@vitest/coverage-v8": "^4.1.6",
    "eslint": "^8.57.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "prettier": "^3.8.3",
    "vite": "^5.2.0",
    "vitest": "^4.1.6"
  }
}